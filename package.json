{
    "name": "@cion-suite/template",
    "version": "0.0.0",
    "packageManager": "pnpm@11.1.2",
    "engines": {
        "node": ">=24.15.0",
        "pnpm": ">=11.1.2"
    },
    "private": true,
    "description": "Reference template skeleton — minimal Electron app consuming Cion Suite packages.",
    "license": "GPL-3.0-or-later",
    "author": "Cion Suite",
    "homepage": "https://github.com/cion-suite/cion-template",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cion-suite/cion-template.git"
    },
    "bugs": {
        "url": "https://github.com/cion-suite/cion-template/issues"
    },
    "type": "module",
    "main": "build/out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "check:placeholders": "node scripts/check-placeholders.mjs",
        "dist": "pnpm check:placeholders && electron-vite build && electron-builder --config electron-builder.json",
        "dist:beta": "pnpm check:placeholders && electron-vite build && electron-builder --config electron-builder.beta.json",
        "typecheck": "tsc -b --noEmit .",
        "lint": "eslint .",
        "ship": "pnpm typecheck && pnpm lint && pnpm build"
    },
    "dependencies": {
        "@cion-suite/core": "link:../cion-suite/packages/core",
        "electron-updater": "^6.8.3"
    },
    "devDependencies": {
        "@cion-suite/config": "link:../cion-suite/packages/config",
        "@eslint/js": "^9.30.1",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/roboto": "^5.2.10",
        "@tailwindcss/vite": "^4.1.11",
        "@tanstack/react-query": "^5.83.0",
        "@types/node": "^24.12.4",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.3",
        "babel-plugin-react-compiler": "^1.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron": "^40.8.2",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "eslint": "^9.30.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "i18next": "^25.7.1",
        "lucide-react": "^1.16.0",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.0.0",
        "react-i18next": "^16.1.0",
        "react-router-dom": "^7.13.0",
        "shadcn": "^4.7.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.1.17",
        "tw-animate-css": "^1.4.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.35.1",
        "vite": "^7.3.2",
        "zod": "^4.3.6"
    }
}
